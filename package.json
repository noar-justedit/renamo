{
  "name": "renamo",
  "version": "1.5.4",
  "description": "Batch file renamer",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --arm64",
    "build:mac-universal": "electron-builder --mac dmg --universal",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.justedit.renamo",
    "productName": "renamo",
    "copyright": "Copyright \u00a9 2026 just edit",
    "files": [
      "src/**/*",
      "build/icon.icns",
      "build/icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "minimumSystemVersion": "11.0",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "renamo ${version}",
      "icon": "build/icon.icns",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 190,
          "type": "file"
        },
        {
          "x": 390,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "artifactName": "renamo-${version}-mac-${arch}.dmg"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "renamo-${version}-win-${arch}.zip"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "renamo",
      "license": "build/license.txt",
      "artifactName": "renamo-Setup-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.15.3",
    "dmg-license": "^1.0.11"
  },
  "dependencies": {},
  "author": "just edit",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/noar-justedit/renamo.git"
  },
  "homepage": "https://github.com/noar-justedit/renamo",
  "bugs": {
    "url": "https://github.com/noar-justedit/renamo/issues"
  }
}
